{
  "name": "ascii-buddy",
  "version": "0.1.0",
  "description": "A terminal ASCII companion that speaks developer wisdom",
  "type": "module",
  "bin": {
    "ascii-buddy": "./dist/main.js"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/main.js",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": ["terminal", "ascii", "tamagotchi", "cli", "companion"],
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "neo-blessed": "^0.2.0",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "msw": "^2.0.0",
    "prettier": "^3.0.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
